# Copy to .env and fill in for local development.
# Never commit a populated .env.

PORT=8080
APP_ENV=development

# Postgres connection URI. Format: postgres://USER:PASS@HOST:PORT/DB?opts
# For local Docker setup: see docs/code-walkthrough.md "Operations cheatsheet".
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/credflow?sslmode=disable

DB_MAX_CONNS=10
DB_MIN_CONNS=2
